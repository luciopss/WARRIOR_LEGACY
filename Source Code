function renderShop(){
  document.getElementById('goldAmt').textContent=playerGold;
  const grid=document.getElementById('shopGrid');grid.innerHTML='';
  WEAPONS.forEach(w=>{
    const div=document.createElement('div');div.className='shop-card'+(w.owned?' owned':'');
    const up=w.level*80;
    div.innerHTML=`<div class="item-icon">${w.icon}</div><div class="item-name">${w.name}</div><div class="item-desc">${w.special}</div><div class="item-stats">DMG: ${w.dmgL}–${w.dmgH} | Sp: ${w.spDmg} | Lv.${w.level}</div><div class="item-price" style="margin-top:8px">${!w.owned?`🪙 ${w.price} <span style="color:#aaa;font-size:10px">to buy</span>`:`🪙 ${up} <span style="color:#aaa;font-size:10px">upgrade</span>`}</div>`;
    div.onclick=()=>{sfx('click');shopAction(w);};grid.appendChild(div);
  });
}
function shopAction(w){
  if(!w.owned){if(playerGold<w.price){notify('⚠ Not enough gold!');return;}openModal(`Purchase ${w.name}?`,`Cost: 🪙 ${w.price} gold\nDamage: ${w.dmgL}–${w.dmgH} | Special: ${w.special} (${w.spDmg} dmg)`,()=>{w.owned=true;playerGold-=w.price;sfx('purchase');notify(`✓ ${w.name} added to armoury!`);renderShop();});}
  else{const p=w.level*80;if(w.level>=5){notify('⚔ Already at max level!');return;}if(playerGold<p){notify('⚠ Not enough gold!');return;}openModal(`Upgrade ${w.name} to Lv.${w.level+1}?`,`Cost: 🪙 ${p} gold\nDamage will increase by 4–8\nSpecial damage +10`,()=>{w.level++;w.dmgL+=4;w.dmgH+=8;w.spDmg+=10;playerGold-=p;sfx('purchase');notify(`⬆ ${w.name} upgraded to Level ${w.level}!`);renderShop();});}
}
