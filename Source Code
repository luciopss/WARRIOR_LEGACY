function renderClassSelect(){
  ['p1','p2'].forEach((p,pi)=>{
    const row=document.getElementById(`${p}ClassRow`);row.innerHTML='';
    CLASSES.forEach(cl=>{
      const div=document.createElement('div');
      const selP1=p1ClassId===cl.id,selP2=p2ClassId===cl.id;
      let cls='class-card';
      if(pi===0&&selP1)cls+=' selected-p1';
      if(pi===1&&selP2)cls+=' selected-p2';
      div.className=cls;
      div.innerHTML=`<div class="class-card-icon">${cl.icon}</div><div class="class-card-name">${cl.name}</div><div class="class-card-skill">${cl.passive.split(':')[0]}</div>`;
      div.onclick=()=>{sfx('select');if(pi===0)p1ClassId=cl.id;else p2ClassId=cl.id;renderClassSelect();};
      row.appendChild(div);
    });
  });
}

