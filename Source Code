const runeRing=document.getElementById('runeRing');
for(let i=0;i<16;i++){const a=(i/16)*360,r=(a*Math.PI)/180,cx=170,cy=170,rad=155,x=cx+rad*Math.cos(r),y=cy+rad*Math.sin(r),el=document.createElement('div');el.className='rune';el.textContent=runes[i%runes.length];el.style.left=x+'px';el.style.top=y+'px';el.style.transform=`translate(-50%,-50%) rotate(${a+90}deg)`;el.style.animationDelay=(i*.15)+'s';runeRing.appendChild(el);}
