// ══════════════════════════════════════════
//  GAME ENGINE
// ══════════════════════════════════════════
const canvas=document.getElementById('gameCanvas');
const ctx=canvas.getContext('2d');
let gameState=null,animFrame=null;
const FLOOR_Y=()=>canvas.height*.76;
const GRAVITY=0.6,JUMP_VEL=-14;
function getWeapon(id){return WEAPONS.find(w=>w.id===id);}
function getClass(id){return CLASSES.find(c=>c.id===id);}

function createFighter(x,isP1,weaponId,classId){
  return {
    x,y:0,vy:0,vx:0,w:50,h:90,isP1,
    hp:200,maxHp:200,stamina:100,maxSt:100,
    weapon:getWeapon(weaponId),cls:getClass(classId),
    facing:isP1?1:-1,state:'idle',
    attackFrame:0,attackType:null,spCooldown:0,hurtFrame:0,onGround:false,wins:0,
    // Rage / Berserk
    rage:0,maxRage:100,berserk:false,berserkTimer:0,
    // Transformation animation
    transformFrame:0,transforming:false,
    // Buffs from orbs
    atkBuff:0,spdBuff:0,burnTick:0,orbsCollected:[],
    // Class: burn ticks from shaman
    burnApplied:0,
    // Internal
    _wasBlocking:false,
    // Visual shake
    shakeX:0,shakeY:0,
  };
}

function startBattle(){showScreen('gameScreen');bgmCurrentPhase='battle';startBGM('battle');initGame();}
function initGame(){
  canvas.width=window.innerWidth;canvas.height=window.innerHeight;
  gameState={
    p1:createFighter(canvas.width*.25,true,p1WeaponId,p1ClassId),
    p2:createFighter(canvas.width*.75,false,p2WeaponId,p2ClassId),
    round:1,maxRounds:3,timer:60,timerTick:0,
    phase:'countdown',countdownVal:3,countdownTick:0,
    keys:{},hitEffects:[],bgScrollX:0,
    orbs:[],orbSpawnTick:0,orbSpawnInterval:300,
    screenShake:0,
  };
  gameState.p2.facing=-1;
  document.onkeydown=e=>{gameState.keys[e.code]=true;e.preventDefault();};
  document.onkeyup=e=>{gameState.keys[e.code]=false;};
  document.getElementById('roundNum').textContent=gameState.round;
  document.getElementById('victoryOverlay').classList.remove('show');
  // Update class badges
  const p1cls=getClass(p1ClassId),p2cls=getClass(p2ClassId);
  document.getElementById('p1ClassBadge').textContent=`${p1cls.icon} ${p1cls.name.toUpperCase()}`;
  document.getElementById('p2ClassBadge').textContent=`${p2cls.icon} ${p2cls.name.toUpperCase()}`;
  // Init orb pips
  renderOrbPips(gameState.p1);renderOrbPips(gameState.p2);
  if(animFrame)cancelAnimationFrame(animFrame);
  announceText('3',true);sfx('countdown');
  gameState.phase='countdown';
  loop();
}
function restartBattle(){document.getElementById('victoryOverlay').classList.remove('show');if(bgmCurrentPhase!=='battle'){bgmCurrentPhase='battle';startBGM('battle');}initGame();}

function renderOrbPips(f){
  const id=(f.isP1?'p1':'p2')+'OrbPips';
  const el=document.getElementById(id);el.innerHTML='';
  const recent=f.orbsCollected.slice(-5);
  recent.forEach(t=>{const pip=document.createElement('div');pip.className=`orb-pip filled-${t}`;el.appendChild(pip);});
}

function announceText(text,quick){const el=document.getElementById('announceText');el.textContent=text;el.classList.add('show');setTimeout(()=>el.classList.remove('show'),quick?700:1500);}

// ── MAIN LOOP ──
function loop(){update();render();animFrame=requestAnimationFrame(loop);}

function update(){
  const gs=gameState;if(!gs)return;
  gs.bgScrollX=(gs.bgScrollX+.3)%canvas.width;
  if(gs.screenShake>0)gs.screenShake--;

  if(gs.phase==='countdown'){
    gs.countdownTick++;
    if(gs.countdownTick>=60){gs.countdownTick=0;gs.countdownVal--;
      if(gs.countdownVal>0){announceText(String(gs.countdownVal),true);sfx('countdown');}
      else{gs.phase='fight';announceText('⚔ FIGHT! ⚔',false);sfx('fight_shout');spawnInitialOrbs();}
    }
    updateFighters();return;
  }
  if(gs.phase!=='fight')return;

  gs.timerTick++;
  if(gs.timerTick>=60){gs.timerTick=0;gs.timer--;const td=document.getElementById('timerDisplay');td.textContent=gs.timer;td.className='timer-display'+(gs.timer<=10?' urgent':'');if(gs.timer<=0)endRound();}

  updateFighters();
  updateOrbs();
  checkCollisions();
  updateParticles();
  updateHUD();
  if(gs.p1.hp<=0||gs.p2.hp<=0)endRound();
}

function spawnInitialOrbs(){
  const gs=gameState;
  // Spawn 2 orbs at start on each side
  spawnOrb(canvas.width*.15);
  spawnOrb(canvas.width*.85);
}

function spawnOrb(xHint){
  const gs=gameState;
  const type=ORB_TYPES[Math.floor(Math.random()*ORB_TYPES.length)];
  const floor=FLOOR_Y();
  gs.orbs.push({
    x: xHint || (Math.random()*(canvas.width*.8)+canvas.width*.1),
    y: floor-20,
    type,
    pulse:0,
    spin:0,
    life:600, // auto-despawn
    collected:false,
    spawnAnim:30, // entrance bounce frames
  });
}

function updateOrbs(){
  const gs=gameState;
  // Spawn timer
  gs.orbSpawnTick++;
  if(gs.orbSpawnTick>=gs.orbSpawnInterval){
    gs.orbSpawnTick=0;
    // Spawn orb favoring the side with less HP (give underdog a chance)
    const p1low=gs.p1.hp<gs.p2.hp;
    const xZone=p1low?(Math.random()*.4):(Math.random()*.4+.6);
    spawnOrb(canvas.width*xZone);
    gs.orbSpawnInterval=200+Math.random()*200; // randomize next spawn
  }

  gs.orbs=gs.orbs.filter(o=>!o.collected&&o.life>0);
  gs.orbs.forEach(o=>{
    o.life--;o.pulse+=.08;o.spin+=.03;
    if(o.spawnAnim>0)o.spawnAnim--;
    // Check pickup for both fighters
    [gs.p1,gs.p2].forEach(f=>{
      const dx=(f.x+f.w/2)-o.x, dy=(f.y+f.h/2)-o.y;
      if(Math.sqrt(dx*dx+dy*dy)<35){
        applyOrbEffect(f,o.type);
        o.collected=true;
        sfx('orb_pickup');
        // Spawn collect particles
        for(let i=0;i<12;i++){
          gs.hitEffects.push({x:o.x,y:o.y,vx:(Math.random()-.5)*6,vy:(Math.random()-.5)*6-2,life:35,maxLife:35,color:o.type.color,size:Math.random()*5+2,isOrb:true});
        }
        // Floating text
        gs.hitEffects.push({x:o.x,y:o.y-20,vx:0,vy:-1,life:60,maxLife:60,color:o.type.color,text:o.type.label,isText:true});
      }
    });
  });
}

function applyOrbEffect(f,type){
  f.orbsCollected.push(type.id);
  if(f.orbsCollected.length>5)f.orbsCollected.shift();
  renderOrbPips(f);

  switch(type.id){
    case 'hp':
      f.hp=Math.min(f.maxHp,f.hp+40);
      notify(`${f.isP1?'P1':'P2'} ❤ +40 HP restored!`);
      break;
    case 'atk':
      f.atkBuff=480; // 8 seconds at 60fps
      notify(`${f.isP1?'P1':'P2'} 🔥 +25% Attack Power!`);
      break;
    case 'spd':
      f.spdBuff=480;
      notify(`${f.isP1?'P1':'P2'} 💨 Swift Boots activated!`);
      break;
    case 'rage':
      f.rage=Math.min(f.maxRage,f.rage+60);
      sfx('rage_fill');
      notify(`${f.isP1?'P1':'P2'} ⚡ Rage surges!`);
      break;
  }
}

function updateFighters(){
  const gs=gameState;const floor=FLOOR_Y();
  [gs.p1,gs.p2].forEach((f,i)=>{
    const isP1=i===0;
    const K=gs.keys;
    const left=isP1?'KeyA':'ArrowLeft',right=isP1?'KeyD':'ArrowRight';
    const jump=isP1?'KeyW':'ArrowUp',block=isP1?'KeyS':'ArrowDown';
    const la=isP1?'KeyF':'Numpad1',ha=isP1?'KeyG':'Numpad2',sa=isP1?'KeyH':'Numpad3';
    const berserkKey=isP1?'KeyR':'Numpad0';

    // Tick buffs
    if(f.atkBuff>0)f.atkBuff--;
    if(f.spdBuff>0)f.spdBuff--;

    // Burn from shaman
    if(f.burnApplied>0){f.burnApplied--;if(f.burnApplied%60===0){f.hp=Math.max(0,f.hp-3);spawnHitEffect(f,'burn');}}

    // Berserk timer
    if(f.berserk){
      f.berserkTimer--;
      if(f.berserkTimer<=0){
        f.berserk=false;f.rage=0;
        sfx('berserk_end');
        document.getElementById((isP1?'p1':'p2')+'Berserk').classList.remove('active');
        notify(`${isP1?'P1':'P2'} Berserker mode ended!`);
        spawnTransformEffect(f,'end');
      }
    }

    // Transformation animation
    if(f.transforming){f.transformFrame--;if(f.transformFrame<=0){f.transforming=false;f.transformFrame=0;}}

    if(gs.phase!=='fight'){updatePhysics(f,floor);return;}
    if(f.state==='dead'||f.hurtFrame>0){f.hurtFrame=Math.max(0,f.hurtFrame-1);updatePhysics(f,floor);return;}
    if(f.spCooldown>0)f.spCooldown--;
    f.stamina=Math.min(f.maxSt,f.stamina+.2);
    if(f.attackFrame>0){f.attackFrame--;updatePhysics(f,floor);return;}

    f.state='idle';f.vx=0;

    // BERSERK ACTIVATION
    if(K[berserkKey]&&f.rage>=f.maxRage&&!f.berserk){
      activateBerserk(f,isP1);
    }

    if(K[block]){
      f.state='block';
      if(!f._wasBlocking){f._wasBlocking=true;sfx('block');}
      updatePhysics(f,floor);return;
    }else{f._wasBlocking=false;}

    const spd=f.berserk?(f.cls.id==='berserker'?6:f.cls.id==='shadow'?7:5):(f.spdBuff>0?6:4);
    if(K[left]){f.vx=-spd;f.facing=-1;f.state='walk';}
    if(K[right]){f.vx=spd;f.facing=1;f.state='walk';}
    if(K[jump]&&f.onGround){f.vy=JUMP_VEL;f.onGround=false;f.state='jump';sfx('jump');}

    if(K[sa]&&f.spCooldown<=0&&f.stamina>=30){
      f.attackType='special';f.attackFrame=25;f.stamina-=30;f.spCooldown=180;spawnHitEffect(f,'special');
    }else if(K[ha]&&f.stamina>=20){f.attackType='heavy';f.attackFrame=20;f.stamina-=20;}
    else if(K[la]&&f.stamina>=8){f.attackType='light';f.attackFrame=12;f.stamina-=8;}

    if(f.attackFrame>0)f.state='attack';
    updatePhysics(f,floor);
  });
}

function activateBerserk(f,isP1){
  f.berserk=true;f.berserkTimer=f.cls.berserkDur;
  f.transforming=true;f.transformFrame=40;
  sfx('berserk_activate');
  gs_screen_shake(20);
  document.getElementById((isP1?'p1':'p2')+'Berserk').classList.add('active');
  announceText(`🔥 ${f.cls.berserk.split(':')[0].toUpperCase()} 🔥`,false);
  spawnTransformEffect(f,'start');
  notify(`${isP1?'P1':'P2'} ⚡ ${f.cls.name} Berserker Mode!`);
}
function gs_screen_shake(amt){if(gameState)gameState.screenShake=amt;}

function spawnTransformEffect(f,phase){
  const gs=gameState;if(!gs)return;
  const col=f.cls.berserkColor;
  for(let i=0;i<30;i++){
    const a=(i/30)*Math.PI*2;
    gs.hitEffects.push({
      x:f.x+f.w/2,y:f.y+f.h/2,
      vx:Math.cos(a)*(phase==='start'?8:4),vy:Math.sin(a)*(phase==='start'?8:4)-3,
      life:50,maxLife:50,color:col,size:Math.random()*8+3,
    });
  }
}

function updatePhysics(f,floor){
  f.vy+=GRAVITY;f.x+=f.vx;f.y+=f.vy;
  if(f.y+f.h>=floor){f.y=floor-f.h;f.vy=0;f.onGround=true;}
  f.x=Math.max(10,Math.min(canvas.width-f.w-10,f.x));
}

function checkCollisions(){
  const gs=gameState;const p1=gs.p1,p2=gs.p2;
  if(p1.x<p2.x){p1.facing=1;p2.facing=-1;}else{p1.facing=-1;p2.facing=1;}
  [p1,p2].forEach((att,i)=>{
    const def=i===0?p2:p1;
    if(att.attackFrame===0||att.state!=='attack')return;
    if(att.attackFrame!==(att.attackType==='light'?6:att.attackType==='heavy'?10:12))return;
    const reach=90;
    if(Math.abs(att.x-def.x)>=reach)return;

    let dmg=att.attackType==='light'?att.weapon.dmgL:att.attackType==='heavy'?att.weapon.dmgH:att.weapon.spDmg;

    // Class passives on damage
    if(att.cls.id==='shadow'&&att.facing!==def.facing)dmg=Math.floor(dmg*1.4); // Backstab
    if(att.cls.id==='titan')dmg=Math.floor(dmg*0.8); // Slower
    if(att.berserk)dmg=Math.floor(dmg*att.cls.berserkDmg);
    if(att.atkBuff>0)dmg=Math.floor(dmg*1.25);

    let blockMult=att.cls.id==='paladin'?0.1:0.25;
    if(def.state==='block')dmg=Math.floor(dmg*blockMult);
    if(def.cls.id==='titan')dmg=Math.floor(dmg*.8); // Iron Skin

    def.hp=Math.max(0,def.hp-dmg);
    def.hurtFrame=def.state==='block'?5:15;
    def.shakeX=(Math.random()-.5)*8;def.shakeY=(Math.random()-.5)*4;

    // Rage generation from dealing and taking damage
    att.rage=Math.min(att.maxRage,att.rage+dmg*.3);
    def.rage=Math.min(def.maxRage,def.rage+(def.cls.id==='berserker'?dmg*.5:dmg*.2));

    // Shaman burn
    if(att.cls.id==='shaman'||(att.berserk&&att.cls.id==='shaman'))def.burnApplied=180;

    // Titan shockwave
    if(att.berserk&&att.cls.id==='titan'&&att.attackType==='heavy'){spawnShockwave(att);}

    if(att.attackType==='special')sfx('hit_special');
    else if(att.attackType==='heavy')sfx('hit_heavy');
    else sfx('hit_light');

    spawnHitEffect(def,att.attackType);
    playerGold+=Math.floor(dmg*.5);
    gs_screen_shake(att.attackType==='heavy'?8:att.attackType==='special'?15:3);
  });
}

function spawnShockwave(f){
  const gs=gameState;const floor=FLOOR_Y();
  for(let i=0;i<20;i++){
    gs.hitEffects.push({x:f.x+f.w/2+(i*15*f.facing),y:floor-5,vx:f.facing*2,vy:-Math.random()*3-1,life:25,maxLife:25,color:'#888888',size:Math.random()*5+3});
  }
}

function spawnHitEffect(f,type){
  const gs=gameState;
  const col={light:'#88ccff',heavy:'#ffaa33',special:'#ff4444',burn:'#ff6600'}[type]||'#fff';
  for(let i=0;i<(type==='special'?20:8);i++){
    gs.hitEffects.push({x:f.x+f.w/2,y:f.y+f.h/2,vx:(Math.random()-.5)*8,vy:(Math.random()-.5)*8-2,life:30,maxLife:30,color:col,size:Math.random()*6+2});
  }
}

function updateParticles(){
  const gs=gameState;
  gs.hitEffects=gs.hitEffects.filter(p=>p.life>0);
  gs.hitEffects.forEach(p=>{if(!p.isText){p.x+=p.vx;p.y+=p.vy;p.vy+=.3;}else{p.y+=p.vy;}p.life--;});
}

function updateHUD(){
  const gs=gameState;const p1=gs.p1,p2=gs.p2;
  const pct=f=>Math.max(0,f.hp/f.maxHp*100)+'%';
  document.getElementById('p1Health').style.width=pct(p1);
  document.getElementById('p2Health').style.width=pct(p2);
  document.getElementById('p1Stamina').style.width=Math.max(0,p1.stamina/p1.maxSt*100)+'%';
  document.getElementById('p2Stamina').style.width=Math.max(0,p2.stamina/p2.maxSt*100)+'%';
  const r1=document.getElementById('p1Rage'),r2=document.getElementById('p2Rage');
  r1.style.width=Math.max(0,p1.rage/p1.maxRage*100)+'%';
  r2.style.width=Math.max(0,p2.rage/p2.maxRage*100)+'%';
  r1.className='rage-bar-fill'+(p1.rage>=p1.maxRage?' full':'');
  r2.className='rage-bar-fill'+(p2.rage>=p2.maxRage?' full':'');
}

function endRound(){
  const gs=gameState;if(gs.phase!=='fight')return;gs.phase='roundEnd';
  let winner=null;
  if(gs.p1.hp<=0&&gs.p2.hp>0)winner=gs.p2;
  else if(gs.p2.hp<=0&&gs.p1.hp>0)winner=gs.p1;
  else if(gs.p1.hp>gs.p2.hp)winner=gs.p1;
  else if(gs.p2.hp>gs.p1.hp)winner=gs.p2;
  if(winner)winner.wins++;
  if(winner&&winner.wins>=2){setTimeout(()=>showVictory(winner),1000);return;}
  gs.round++;document.getElementById('roundNum').textContent=gs.round;
  announceText(winner?'ROUND '+(gs.round-1):'DRAW',false);
  setTimeout(()=>{
    const floor=FLOOR_Y();
    [gs.p1,gs.p2].forEach((f,i)=>{
      f.hp=f.maxHp;f.stamina=f.maxSt;f.rage=0;f.berserk=false;f.berserkTimer=0;
      f.atkBuff=0;f.spdBuff=0;f.burnApplied=0;
      document.getElementById((i===0?'p1':'p2')+'Berserk').classList.remove('active');
      f.x=canvas.width*(i===0?.25:.75);f.y=floor-f.h;
    });
    gs.orbs=[];
    gs.timer=60;gs.timerTick=0;
    document.getElementById('timerDisplay').textContent='60';
    document.getElementById('timerDisplay').className='timer-display';
    gs.countdownVal=3;gs.countdownTick=0;gs.phase='countdown';
    announceText('3',true);sfx('countdown');
  },2000);
}
function showVictory(winner){
  const gs=gameState;gs.phase='gameEnd';
  document.getElementById('victoryName').textContent=winner.isP1?'PLAYER  ONE':'PLAYER  TWO';
  document.getElementById('victorySub').textContent=`${winner.cls.name} – Master of the ${winner.weapon.name}!`;
  document.getElementById('victoryOverlay').classList.add('show');
  playerGold+=100;notify('🪙 +100 Victory Gold!');sfx('victory');
  setTimeout(()=>{bgmCurrentPhase='menu';startBGM('menu');},2000);
}

// ══════════════════════════════════════════
//  RENDER
// ══════════════════════════════════════════
function render(){
  const gs=gameState;if(!gs)return;
  ctx.clearRect(0,0,canvas.width,canvas.height);

  // Screen shake
  if(gs.screenShake>0){ctx.save();ctx.translate((Math.random()-.5)*gs.screenShake*.5,(Math.random()-.5)*gs.screenShake*.3);}

  drawBackground();drawFloor();
  drawOrbs();
  drawFighter(gs.p1);drawFighter(gs.p2);
  drawParticles();

  if(gs.screenShake>0)ctx.restore();
}

function drawBackground(){
  const w=canvas.width,h=canvas.height;
  const sky=ctx.createLinearGradient(0,0,0,h*.75);
  sky.addColorStop(0,'#0a0510');sky.addColorStop(.4,'#1a0a15');sky.addColorStop(1,'#2a1510');
  ctx.fillStyle=sky;ctx.fillRect(0,0,w,h);
  ctx.save();ctx.shadowBlur=40;ctx.shadowColor='rgba(200,180,120,.4)';ctx.fillStyle='#d4c07a';ctx.beginPath();ctx.arc(w*.85,h*.12,45,0,Math.PI*2);ctx.fill();ctx.fillStyle='#1a0a15';ctx.beginPath();ctx.arc(w*.87,h*.10,38,0,Math.PI*2);ctx.fill();ctx.restore();
  ctx.fillStyle='rgba(255,255,200,.7)';[[.1,.05],[.2,.08],[.35,.03],[.5,.06],[.6,.02],[.7,.09],[.15,.15],[.45,.12],[.62,.14],[.78,.07],[.92,.18]].forEach(([sx,sy])=>{ctx.beginPath();ctx.arc(sx*w,sy*h,1.5,0,Math.PI*2);ctx.fill();});
  ctx.fillStyle='rgba(20,10,5,.8)';const cx=w*.3;[[0,80,30,120],[35,90,20,110],[65,85,30,115]].forEach(([dx,tw,dw,th])=>{ctx.fillRect(cx+dx,h*.55-th,dw,th);for(let b=0;b<3;b++)ctx.fillRect(cx+dx+b*(dw/3),h*.55-th-12,dw/3-3,12);});
  [.08,.3,.55,.72,.9].forEach(tx=>{const fl=.6+Math.sin(Date.now()*.005+tx*10)*.3,grd=ctx.createRadialGradient(tx*w,h*.73,0,tx*w,h*.73,40*fl);grd.addColorStop(0,`rgba(255,150,30,${.3*fl})`);grd.addColorStop(1,'transparent');ctx.fillStyle=grd;ctx.fillRect(tx*w-40*fl,h*.73-40*fl,80*fl,80*fl);ctx.fillStyle='#ff8830';ctx.beginPath();ctx.arc(tx*w,h*.735,3,0,Math.PI*2);ctx.fill();});
  ctx.fillStyle='rgba(15,8,3,.4)';ctx.fillRect(0,h*.74,w,h*.26);
}

function drawFloor(){
  const h=canvas.height,w=canvas.width,fy=FLOOR_Y();
  const grd=ctx.createLinearGradient(0,fy,0,h);grd.addColorStop(0,'#1a1008');grd.addColorStop(1,'#0a0805');ctx.fillStyle=grd;ctx.fillRect(0,fy,w,h-fy);
  ctx.save();ctx.shadowBlur=15;ctx.shadowColor='rgba(201,168,76,.3)';ctx.strokeStyle='rgba(201,168,76,.5)';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(0,fy);ctx.lineTo(w,fy);ctx.stroke();ctx.restore();
  ctx.strokeStyle='rgba(60,40,20,.5)';ctx.lineWidth=1;
  for(let x=0;x<w;x+=80){ctx.beginPath();ctx.moveTo(x,fy);ctx.lineTo(x,fy+20);ctx.stroke();}
  ctx.beginPath();ctx.moveTo(0,fy+20);ctx.lineTo(w,fy+20);ctx.stroke();
}

function drawOrbs(){
  const gs=gameState;if(!gs)return;
  gs.orbs.forEach(o=>{
    const t=Date.now()*.002;
    const bounceY=o.spawnAnim>0?-Math.sin((1-o.spawnAnim/30)*Math.PI)*20:0;
    const hoverY=Math.sin(t*2+o.x*.01)*5;
    const y=o.y+bounceY+hoverY;
    const pulse=.7+Math.sin(o.pulse)*.3;
    const fadeAlpha=o.life<60?o.life/60:1;

    ctx.save();
    ctx.globalAlpha=fadeAlpha;

    // Outer glow ring
    ctx.save();
    ctx.shadowBlur=20*pulse;ctx.shadowColor=o.type.glow;
    const grd=ctx.createRadialGradient(o.x,y,0,o.x,y,18*pulse);
    grd.addColorStop(0,'rgba(255,255,255,.9)');
    grd.addColorStop(.3,o.type.color);
    grd.addColorStop(1,'transparent');
    ctx.fillStyle=grd;
    ctx.beginPath();ctx.arc(o.x,y,18*pulse,0,Math.PI*2);ctx.fill();
    ctx.restore();

    // Inner orb
    ctx.beginPath();ctx.arc(o.x,y,10,0,Math.PI*2);
    ctx.fillStyle=o.type.color;ctx.shadowBlur=15;ctx.shadowColor=o.type.glow;ctx.fill();

    // Spinning rune ring
    ctx.save();ctx.translate(o.x,y);ctx.rotate(o.spin);
    ctx.strokeStyle=o.type.color;ctx.lineWidth=1.5;ctx.globalAlpha=.5*fadeAlpha;
    ctx.setLineDash([3,5]);ctx.beginPath();ctx.arc(0,0,16,0,Math.PI*2);ctx.stroke();
    ctx.setLineDash([]);ctx.restore();

    // Label
    ctx.font='bold 9px Cinzel';ctx.fillStyle=o.type.color;ctx.textAlign='center';ctx.shadowBlur=8;ctx.shadowColor=o.type.glow;
    ctx.fillText(o.type.label,o.x,y-24);

    ctx.restore();
  });
}

function drawFighter(f){
  const t=Date.now();
  ctx.save();

  // Berserk aura
  if(f.berserk){
    const aura=ctx.createRadialGradient(f.x+f.w/2,f.y+f.h/2,0,f.x+f.w/2,f.y+f.h/2,70);
    aura.addColorStop(0,f.cls.berserkGlow);aura.addColorStop(1,'transparent');
    ctx.fillStyle=aura;ctx.beginPath();ctx.arc(f.x+f.w/2,f.y+f.h/2,70,0,Math.PI*2);ctx.fill();
    // Rotating rune ring
    ctx.save();ctx.translate(f.x+f.w/2,f.y+f.h/2);ctx.rotate(t*.002*(f.isP1?1:-1));
    ctx.strokeStyle=f.cls.berserkColor;ctx.lineWidth=2;ctx.globalAlpha=.4+Math.sin(t*.01)*.2;
    ctx.setLineDash([5,8]);ctx.beginPath();ctx.arc(0,0,55,0,Math.PI*2);ctx.stroke();
    ctx.setLineDash([]);ctx.restore();
  }

  // Transformation flash
  if(f.transforming){
    const prog=1-f.transformFrame/40;
    ctx.save();
    ctx.globalAlpha=Math.sin(prog*Math.PI)*.8;
    ctx.fillStyle=f.cls.berserkColor;
    ctx.shadowBlur=50;ctx.shadowColor=f.cls.berserkGlow;
    ctx.beginPath();ctx.arc(f.x+f.w/2,f.y+f.h/2,60*prog,0,Math.PI*2);ctx.fill();
    ctx.restore();
  }

  // Shadow Phantom trail (shadow class in berserk)
  if(f.berserk&&f.cls.id==='shadow'){
    for(let i=1;i<=3;i++){
      ctx.save();ctx.globalAlpha=.15/i;ctx.translate(f.x+f.w/2-f.vx*i*3,f.y);ctx.scale(f.facing,1);
      ctx.fillStyle='#8844ff';ctx.fillRect(-18,f.h*.25,36,f.h*.35);ctx.restore();
    }
  }

  ctx.save();
  ctx.translate(f.x+f.w/2+(f.shakeX*f.hurtFrame/15),f.y+(f.shakeY*f.hurtFrame/15));
  ctx.scale(f.facing,1);

  const isBlock=f.state==='block',isAtk=f.state==='attack',isHurt=f.hurtFrame>0;

  // Color mod based on class/berserk
  let bodyColor=f.isP1?'#3a6aaa':'#aa3a3a';
  let armorColor=f.isP1?'#2a5080':'#802a2a';
  let hlColor=f.isP1?'#6a9add':'#dd6a6a';

  if(f.berserk){
    const bc=f.cls.berserkColor;
    bodyColor=bc;armorColor=lerpColor(armorColor,bc,.4);hlColor=lerpColor(hlColor,bc,.6);
  }
  if(f.atkBuff>0){bodyColor=lerpColor(bodyColor,'#ff8844',.3);}
  if(f.spdBuff>0){bodyColor=lerpColor(bodyColor,'#88aaff',.2);}

  if(isHurt&&Math.floor(f.hurtFrame/3)%2===0)ctx.filter='brightness(3) saturate(0)';

  // Shadow
  ctx.save();ctx.fillStyle='rgba(0,0,0,.3)';ctx.scale(1,.3);ctx.beginPath();ctx.ellipse(0,f.h/.3,25,12,0,0,Math.PI*2);ctx.fill();ctx.restore();

  // Legs
  const legSway=isAtk?15:(f.vx!==0?Math.sin(t*.01)*12:0);
  const berserkBob=f.berserk?Math.sin(t*.02)*3:0;
  ctx.fillStyle=armorColor;
  ctx.save();ctx.rotate((-legSway*Math.PI)/180);ctx.fillRect(-14,f.h*.55,12,f.h*.42+berserkBob);ctx.fillStyle='#2a2018';ctx.fillRect(-14,f.h*.9,12,f.h*.08);ctx.restore();
  ctx.save();ctx.rotate((legSway*Math.PI)/180);ctx.fillRect(2,f.h*.55,12,f.h*.42+berserkBob);ctx.fillStyle='#2a2018';ctx.fillRect(2,f.h*.9,12,f.h*.08);ctx.restore();

  // Body
  ctx.fillStyle=bodyColor;ctx.fillRect(-18,f.h*.25,36,f.h*.35);
  ctx.fillStyle=armorColor;ctx.fillRect(-14,f.h*.27,28,f.h*.25);
  ctx.fillStyle=hlColor;ctx.fillRect(-10,f.h*.29,8,f.h*.2);

  // Berserk chest glow
  if(f.berserk){
    ctx.save();ctx.globalAlpha=.3+Math.sin(t*.015)*.2;ctx.fillStyle=f.cls.berserkColor;ctx.shadowBlur=15;ctx.shadowColor=f.cls.berserkColor;ctx.fillRect(-8,f.h*.28,16,f.h*.22);ctx.restore();
  }

  // Head
  const headBob=isAtk?-5:(f.berserk?Math.sin(t*.02)*2:0);
  ctx.fillStyle='#c8a87a';ctx.fillRect(-12,f.h*.04+headBob,24,22);
  ctx.fillStyle=armorColor;ctx.fillRect(-13,f.h*.03+headBob,26,14);
  ctx.fillStyle=hlColor;ctx.fillRect(-11,f.h*.04+headBob,6,8);

  // Eyes — glow red in berserk
  const eyeColor=isHurt?'#ff4444':(f.berserk?f.cls.berserkColor:'#fff');
  ctx.fillStyle=eyeColor;
  if(f.berserk){ctx.shadowBlur=8;ctx.shadowColor=f.cls.berserkColor;}
  ctx.fillRect(2,f.h*.07+headBob,5,4);
  ctx.shadowBlur=0;ctx.fillStyle='#000';ctx.fillRect(4,f.h*.08+headBob,3,3);

  // Weapon arm
  const atkSwing=isAtk?(f.attackType==='special'?60:f.attackType==='heavy'?45:30):0;
  ctx.save();ctx.translate(16,f.h*.28);ctx.rotate((atkSwing*Math.PI)/180-.3);
  ctx.fillStyle=bodyColor;ctx.fillRect(0,0,10,28);
  drawWeaponGraphic(ctx,f.weapon.id,f.isP1,f.berserk,f.cls.berserkColor);
  ctx.restore();

  // Shield arm
  ctx.save();ctx.translate(-16,f.h*.28);ctx.rotate(isBlock?.5:.2);
  ctx.fillStyle=bodyColor;ctx.fillRect(-10,0,10,22);
  if(isBlock){
    ctx.fillStyle='#8a7040';ctx.fillRect(-14,-5,14,36);
    if(f.berserk){ctx.globalAlpha=.5;ctx.fillStyle=f.cls.berserkColor;ctx.fillRect(-13,-4,12,34);}
    else{ctx.fillStyle='rgba(201,168,76,.3)';ctx.fillRect(-13,-4,12,34);}
    // Sparkles
    ctx.globalAlpha=1;ctx.fillStyle=f.berserk?f.cls.berserkColor:'rgba(201,168,76,.6)';
    for(let i=0;i<3;i++){const sx=-20+Math.sin(t*.01+i)*8,sy=f.h*.3+Math.cos(t*.01+i)*10;ctx.beginPath();ctx.arc(sx,sy,2,0,Math.PI*2);ctx.fill();}
  }
  ctx.restore();

  ctx.restore(); // flip restore

  // Shaman fire ring in berserk
  if(f.berserk&&f.cls.id==='shaman'){
    ctx.save();ctx.translate(f.x+f.w/2,f.y+f.h*.7);
    for(let i=0;i<8;i++){
      const a=(i/8)*Math.PI*2+t*.004;const r=35+Math.sin(t*.01+i)*5;
      const fx=Math.cos(a)*r,fy=Math.sin(a)*r*.3;
      ctx.fillStyle=`rgba(255,${80+Math.sin(t*.01+i)*50},0,.8)`;
      ctx.shadowBlur=10;ctx.shadowColor='#ff6600';
      ctx.beginPath();ctx.arc(fx,fy,4+Math.sin(t*.015+i)*2,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  }

  // HP bar
  const bw=60,bh=5;
  ctx.fillStyle='rgba(0,0,0,.5)';ctx.fillRect(f.x+f.w/2-bw/2,f.y-14,bw,bh);
  const hpColor=f.hp>f.maxHp*.5?'#44cc44':f.hp>f.maxHp*.25?'#cccc22':'#cc2222';
  ctx.fillStyle=hpColor;
  if(f.berserk){ctx.shadowBlur=6;ctx.shadowColor=f.cls.berserkColor;}
  ctx.fillRect(f.x+f.w/2-bw/2,f.y-14,bw*(f.hp/f.maxHp),bh);
  ctx.shadowBlur=0;

  // ATK/SPD buff indicators
  if(f.atkBuff>0){ctx.font='9px Cinzel';ctx.fillStyle='#ff8844';ctx.textAlign='center';ctx.fillText('⚔+',f.x+f.w/2+20,f.y-10);}
  if(f.spdBuff>0){ctx.font='9px Cinzel';ctx.fillStyle='#88aaff';ctx.textAlign='center';ctx.fillText('💨',f.x+f.w/2-20,f.y-10);}

  ctx.restore();
}

function lerpColor(a,b,t){
  const ah=a.replace('#',''),bh=b.replace('#','');
  const ar=parseInt(ah.substr(0,2),16),ag=parseInt(ah.substr(2,2),16),ab=parseInt(ah.substr(4,2),16);
  const br=parseInt(bh.substr(0,2),16),bg=parseInt(bh.substr(2,2),16),bb=parseInt(bh.substr(4,2),16);
  const rr=Math.round(ar+(br-ar)*t),rg=Math.round(ag+(bg-ag)*t),rb=Math.round(ab+(bb-ab)*t);
  return '#'+rr.toString(16).padStart(2,'0')+rg.toString(16).padStart(2,'0')+rb.toString(16).padStart(2,'0');
}

function drawWeaponGraphic(ctx_,id,isP1,berserk,bColor){
  const c1='#c0c0c0',c2='#888',gold='#d4a030';
  if(berserk){ctx_.shadowBlur=10;ctx_.shadowColor=bColor;}
  ctx_.lineCap='round';
  switch(id){
    case 'sword':ctx_.strokeStyle=berserk?bColor:c1;ctx_.lineWidth=3;ctx_.beginPath();ctx_.moveTo(5,5);ctx_.lineTo(5,-50);ctx_.stroke();ctx_.strokeStyle=gold;ctx_.lineWidth=5;ctx_.beginPath();ctx_.moveTo(-4,8);ctx_.lineTo(14,8);ctx_.stroke();ctx_.fillStyle='#8a5a20';ctx_.fillRect(3,10,4,12);break;
    case 'axe':ctx_.strokeStyle=c2;ctx_.lineWidth=4;ctx_.beginPath();ctx_.moveTo(5,8);ctx_.lineTo(5,-40);ctx_.stroke();ctx_.fillStyle=berserk?bColor:c1;ctx_.beginPath();ctx_.moveTo(5,-40);ctx_.lineTo(20,-50);ctx_.lineTo(20,-25);ctx_.closePath();ctx_.fill();break;
    case 'spear':ctx_.strokeStyle='#8a6020';ctx_.lineWidth=4;ctx_.beginPath();ctx_.moveTo(5,8);ctx_.lineTo(5,-55);ctx_.stroke();ctx_.fillStyle=berserk?bColor:c1;ctx_.beginPath();ctx_.moveTo(0,-55);ctx_.lineTo(10,-55);ctx_.lineTo(5,-70);ctx_.closePath();ctx_.fill();break;
    case 'mace':ctx_.strokeStyle='#8a6020';ctx_.lineWidth=5;ctx_.beginPath();ctx_.moveTo(5,8);ctx_.lineTo(5,-40);ctx_.stroke();ctx_.fillStyle=berserk?bColor:c1;for(let i=0;i<6;i++){ctx_.save();ctx_.translate(5,-40);ctx_.rotate(i*60*Math.PI/180);ctx_.fillRect(-3,-12,6,10);ctx_.restore();}ctx_.beginPath();ctx_.arc(5,-40,8,0,Math.PI*2);ctx_.fillStyle=c2;ctx_.fill();break;
    case 'dagger':ctx_.strokeStyle=berserk?bColor:c1;ctx_.lineWidth=2;ctx_.beginPath();ctx_.moveTo(5,5);ctx_.lineTo(5,-30);ctx_.stroke();ctx_.strokeStyle=gold;ctx_.lineWidth=3;ctx_.beginPath();ctx_.moveTo(0,8);ctx_.lineTo(10,8);ctx_.stroke();break;
    case 'shield':ctx_.fillStyle='#6a4010';ctx_.beginPath();ctx_.moveTo(5,0);ctx_.lineTo(18,-5);ctx_.lineTo(22,-30);ctx_.lineTo(5,-45);ctx_.lineTo(-12,-30);ctx_.lineTo(-8,-5);ctx_.closePath();ctx_.fill();ctx_.strokeStyle=gold;ctx_.lineWidth=2;ctx_.beginPath();ctx_.moveTo(5,0);ctx_.lineTo(18,-5);ctx_.lineTo(22,-30);ctx_.lineTo(5,-45);ctx_.lineTo(-12,-30);ctx_.lineTo(-8,-5);ctx_.closePath();ctx_.stroke();break;
    case 'bow':ctx_.strokeStyle='#6a4010';ctx_.lineWidth=3;ctx_.beginPath();ctx_.arc(5,-20,22,.5,Math.PI-.5);ctx_.stroke();ctx_.strokeStyle='rgba(255,255,200,.4)';ctx_.lineWidth=1;ctx_.beginPath();ctx_.moveTo(5+22*Math.cos(.5),-20+22*Math.sin(.5));ctx_.lineTo(5+22*Math.cos(Math.PI-.5),-20+22*Math.sin(Math.PI-.5));ctx_.stroke();ctx_.strokeStyle='#c0a050';ctx_.lineWidth=2;ctx_.beginPath();ctx_.moveTo(5,-5);ctx_.lineTo(5,-40);ctx_.stroke();break;
    case 'flame':{const flm=Date.now()*.01;ctx_.strokeStyle='#8a6030';ctx_.lineWidth=3;ctx_.beginPath();ctx_.moveTo(5,8);ctx_.lineTo(5,-45);ctx_.stroke();ctx_.fillStyle=`rgba(255,${80+Math.sin(flm)*50},0,.9)`;ctx_.shadowBlur=15;ctx_.beginPath();ctx_.arc(5,-50,10+Math.sin(flm)*4,0,Math.PI*2);ctx_.fill();ctx_.fillStyle=`rgba(255,200,0,.7)`;ctx_.beginPath();ctx_.arc(5,-50,5+Math.sin(flm*1.3)*2,0,Math.PI*2);ctx_.fill();break;}
    default:ctx_.strokeStyle=c1;ctx_.lineWidth=3;ctx_.beginPath();ctx_.moveTo(5,5);ctx_.lineTo(5,-50);ctx_.stroke();
  }
  ctx_.shadowBlur=0;
}

function drawParticles(){
  const gs=gameState;
  gs.hitEffects.forEach(p=>{
    const alpha=p.life/p.maxLife;
    ctx.save();ctx.globalAlpha=alpha;
    if(p.isText){
      ctx.font=`bold 13px Cinzel`;ctx.fillStyle=p.color;ctx.textAlign='center';
      ctx.shadowBlur=8;ctx.shadowColor=p.color;ctx.fillText(p.text,p.x,p.y);
    }else{
      ctx.shadowBlur=10;ctx.shadowColor=p.color;ctx.fillStyle=p.color;
      ctx.beginPath();ctx.arc(p.x,p.y,p.size,0,Math.PI*2);ctx.fill();
    }
    ctx.restore();
  });
}

// BGM init on interaction
let bgmStarted=false;
function ensureBGM(){if(!bgmStarted){bgmStarted=true;bgmCurrentPhase='menu';startBGM('menu');}}
document.addEventListener('click',ensureBGM);
document.addEventListener('keydown',ensureBGM);

// Init
renderClassSelect();
renderWeaponSelect();
renderShop();
